<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1.0.0" author="jonichi">
        <sqlFile path="database-init/create_schema.sql" relativeToChangelogFile="true" />
    </changeSet>
    <changeSet id="1.0.0-tag" author="jonichi">
        <tagDatabase tag="1.0.0-tag" />
    </changeSet>
    <changeSet id="1.0.1" author="jonichi">
        <sqlFile path="database-init/insert_schema.sql" relativeToChangelogFile="true" />
    </changeSet>
    <changeSet id="1.0.1-tag" author="jonichi">
        <tagDatabase tag="1.0.1-tag" />
    </changeSet>
    <changeSet id="1.0.2" author="jonichi">
        <addColumn tableName="profile">
            <column name="profile_picture_id" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="1.0.2-tag" author="jonichi">
        <tagDatabase tag="1.0.2-tag" />
    </changeSet>
    <changeSet id="1.0.3" author="jonichi">
        <addColumn tableName="art">
            <column name="image_id" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="1.0.3-tag" author="jonichi">
        <tagDatabase tag="1.0.3-tag" />
    </changeSet>
</databaseChangeLog>
